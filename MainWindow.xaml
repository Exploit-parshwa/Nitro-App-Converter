<Window x:Class="Nitro_App_Converter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nitro App Converter" Height="500" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#2D2D30"
        Foreground="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,30">
            <TextBlock FontSize="35" FontWeight="Bold" 
                       FontFamily="Calisto MT" Foreground="#FF3E00FF"
                       ><Run Text=" "/><Run Text="NITRO APP CONVERTER "/></TextBlock>
            <TextBlock Text="                    Convert Any Website to Android App in One Click" 
                       FontSize="14"
                       Foreground="#A0A0A0" Height="32" Width="457"/>
        </StackPanel>

        
        <Border Grid.Row="1" CornerRadius="10" Background="#252526" Padding="20">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
              
                
                <Grid>
                    <TextBox Name="WebsiteLinkTextBox" 
                             Width="500" Height="40" Margin="0,0,0,20"
                             Padding="10" FontSize="14" 
                             Background="#333333" Foreground="White"
                             BorderBrush="#404040" BorderThickness="2"
                             GotFocus="WebsiteLinkTextBox_GotFocus" 
                             LostFocus="WebsiteLinkTextBox_LostFocus"
                             Text="https://example.com"/>
                </Grid>

                <!-- Progress Indicators -->
                <ProgressBar Name="BuildProgress" Height="10" Margin="0,0,0,20" 
                             Visibility="Collapsed" Foreground="#00C896"
                             IsIndeterminate="True"/>

                <TextBlock Name="StatusText" Text="" HorizontalAlignment="Center"
                          Foreground="#A0A0A0" Margin="0,0,0,20"/>

                <!-- Action Buttons -->
                <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Name="ConvertToApkButton" Content="CONVERT TO APK" 
                            Width="200" Height="40" Margin="10"
                            Background="#00C896" Foreground="White"
                            BorderThickness="0" FontWeight="Bold"
                            Click="ConvertToApkButton_Click"
                            Cursor="Hand"/>

                    <Button Name="UpgradeToPremiumButton" Content="PREMIUM FEATURES" 
                            Width="200" Height="40" Margin="10"
                            Background="#FFD700" Foreground="#2D2D30"
                            BorderThickness="0" FontWeight="Bold"
                            Click="UpgradeToPremiumButton_Click"
                            ToolTip="Unlock advanced features like custom branding, ads removal, and premium support"
                            Cursor="Hand"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,20,0,0">
            <TextBlock Text="Made with ❤️ by PARSHWA" 
                       Foreground="#707070" FontSize="12"/>
        </StackPanel>
    </Grid>
</Window>
